{
  "name": "@chartoutput/mcp",
  "version": "1.0.7",
  "description": "MCP server for Chart-Output — render Chart.js configs to PNG, SVG, WebP images from any AI agent",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "chart-output-mcp": "build/index.js"
  },
  "files": [
    "build",
    "examples"
  ],
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chart",
    "visualization",
    "chart-output",
    "chartjs",
    "png",
    "image"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "start": "node build/index.js"
  }
}
